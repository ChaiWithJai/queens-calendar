---
import '@fontsource-variable/plus-jakarta-sans';
import '@fontsource/be-vietnam-pro/400.css';
import '@fontsource/be-vietnam-pro/500.css';
import '@fontsource/be-vietnam-pro/600.css';
import '@fontsource/be-vietnam-pro/700.css';
import '../styles/tokens.css';
import '../styles/global.css';
import '../styles/components.css';
import '../styles/characters.css';
import '../styles/compat.css';

interface Props {
	title: string;
	description?: string;
	ogImage?: string;
	currentPath?: string;
	path?: string;
}

const {
	title,
	description = "A community-powered calendar for arts, culture, technology, and neighborhood events across Queens.",
	ogImage = '/images/social/queens-calendar-og.png',
	currentPath: explicitCurrentPath,
	path,
} = Astro.props;

const currentPath = explicitCurrentPath ?? path ?? Astro.url.pathname;
const canonical = new URL(currentPath, Astro.site).toString();
const socialImage = new URL(ogImage, Astro.site).toString();
const fullTitle = title === 'Queens Calendar' ? title : `${title} — Queens Calendar`;
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<link rel="canonical" href={canonical} />
		<link rel="alternate" type="application/rss+xml" title="Queens Calendar stories" href="/feed.xml" />

		<meta property="og:title" content={fullTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={socialImage} />
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="Queens Calendar" />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={fullTitle} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={socialImage} />

		<title>{fullTitle}</title>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
	</head>
	<body>
		<nav class="nav" id="main-nav" aria-label="Main navigation">
			<div class="container nav-inner">
				<a href="/" class="nav-logo" id="nav-logo">
					<span class="nav-logo-icon">QC</span>
					Queens Calendar
				</a>

				<div class="nav-links" id="nav-links">
					<a href="/" class={`nav-link ${currentPath === '/' ? 'active' : ''}`}>This week</a>
					<a
						href="/events"
						class={`nav-link ${currentPath === '/events' || currentPath === '/events/' ? 'active' : ''}`}
						id="nav-events"
					>
						All events
					</a>
					<a
						href="/map"
						class={`nav-link ${currentPath.startsWith('/map') ? 'active' : ''}`}
					>
						Map
					</a>
					<a
						href="/stories"
						class={`nav-link ${currentPath.startsWith('/stories') ? 'active' : ''}`}
					>
						Guides
					</a>
					<a
						href="/schedule"
						class={`nav-link nav-schedule-link ${currentPath === '/schedule' || currentPath === '/schedule/' ? 'active' : ''}`}
						id="nav-schedule"
					>
						My plan
						<span class="nav-schedule-count" id="nav-schedule-count" style="display:none;">0</span>
					</a>
					<a href="/events/submit" class="nav-link">Add an event</a>
				</div>

				<button class="nav-hamburger" id="nav-hamburger" aria-label="Open menu">
					<span></span>
					<span></span>
					<span></span>
				</button>
			</div>
		</nav>

		<div class="mobile-drawer" id="mobile-drawer">
			<div class="mobile-drawer-backdrop" id="drawer-backdrop" aria-hidden="true"></div>
			<div class="mobile-drawer-content" role="dialog" aria-modal="true" aria-label="Navigation menu">
				<button class="mobile-drawer-close" id="drawer-close" aria-label="Close menu">✕</button>
				<a href="/" class="mobile-drawer-link">This week</a>
				<a href="/events" class="mobile-drawer-link">All events</a>
				<a href="/stories" class="mobile-drawer-link">Guides</a>
				<a href="/schedule" class="mobile-drawer-link">My plan</a>
				<a href="/about" class="mobile-drawer-link">About</a>
				<a href="/map" class="mobile-drawer-link">Map</a>
				<a href="/events/submit" class="mobile-drawer-link">Submit event</a>
			</div>
		</div>

		<slot />

		<footer class="footer" id="site-footer" role="contentinfo">
			<div class="container">
				<div class="footer-inner">
					<div class="footer-brand">
						<div class="footer-brand-name">Queens Calendar</div>
						<p class="footer-brand-desc">
							Arts, culture, technology, and community-organized events from across the borough.
						</p>
					</div>
					<div class="footer-col">
						<div class="footer-col-title">Explore</div>
						<a href="/events">All Events</a>
						<a href="/sources">Sources</a>
						<a href="/schedule">My Schedule</a>
						<a href="/map">Map</a>
						<a href="/stories">Stories</a>
					</div>
					<div class="footer-col">
						<div class="footer-col-title">Community</div>
						<a href="/about">About</a>
						<a href="/feed.xml">RSS feed</a>
						<a href="/events/submit">Submit event</a>
					</div>
				</div>
				<div class="footer-bottom">
					<div class="footer-copyright">© 2026 Queens Calendar. Built with and for the borough.</div>
				</div>
			</div>
		</footer>

		<script is:inline>
			// @ts-nocheck
			const STORAGE_KEY = 'queens-calendar-saved-events';

			const getSavedEvents = () => {
				try {
					const raw = localStorage.getItem(STORAGE_KEY);
					const parsed = raw ? JSON.parse(raw) : [];
					return Array.isArray(parsed) ? parsed : [];
				} catch {
					return [];
				}
			};

			const setSavedEvents = (ids) => {
				localStorage.setItem(STORAGE_KEY, JSON.stringify([...new Set(ids)]));
			};

			const syncSavedUI = () => {
				const saved = new Set(getSavedEvents());
				document.querySelectorAll('[data-save-event]').forEach((button) => {
					const id = button.dataset.saveEvent;
					const active = saved.has(id);
					button.dataset.saved = String(active);
					button.classList.toggle('saved', active);
					button.setAttribute('aria-pressed', String(active));
					const label = button.querySelector('[data-save-label]');
					if (label) {
						label.textContent = active ? 'Saved' : 'Save';
					}
					const icon = button.querySelector('svg');
					if (icon) {
						icon.setAttribute('fill', active ? 'currentColor' : 'none');
					}
				});

				const countNode = document.getElementById('nav-schedule-count');
				if (countNode) {
					if (saved.size > 0) {
						countNode.textContent = String(saved.size);
						countNode.style.display = 'inline-flex';
					} else {
						countNode.style.display = 'none';
					}
				}

				document.querySelectorAll('[data-saved-count]').forEach((node) => {
					node.textContent = String(saved.size);
				});
			};

			const toggleSavedEvent = (eventId) => {
				const saved = new Set(getSavedEvents());
				if (saved.has(eventId)) {
					saved.delete(eventId);
				} else {
					saved.add(eventId);
				}
				const next = [...saved];
				setSavedEvents(next);
				syncSavedUI();
				window.dispatchEvent(new CustomEvent('saved-events:updated', { detail: next }));
			};

			const hamburger = document.getElementById('nav-hamburger');
			const drawer = document.getElementById('mobile-drawer');
			const backdrop = document.getElementById('drawer-backdrop');
			const closeBtn = document.getElementById('drawer-close');

			const openDrawer = () => {
				drawer?.classList.add('open');
				document.body.dataset.drawerOpen = 'true';
			};

			const closeDrawer = () => {
				drawer?.classList.remove('open');
				document.body.dataset.drawerOpen = 'false';
			};

			document.addEventListener('click', (event) => {
				const saveButton = event.target.closest('[data-save-event]');
				if (saveButton instanceof HTMLButtonElement) {
					event.preventDefault();
					toggleSavedEvent(saveButton.dataset.saveEvent);
				}
			});

			hamburger?.addEventListener('click', openDrawer);
			backdrop?.addEventListener('click', closeDrawer);
			closeBtn?.addEventListener('click', closeDrawer);

			document.addEventListener('keydown', (event) => {
				if (event.key === 'Escape' && drawer?.classList.contains('open')) {
					closeDrawer();
					hamburger?.focus();
				}
			});

			const charObserver = new IntersectionObserver(
				(entries) => {
					entries.forEach((entry) => {
						if (entry.isIntersecting) {
							entry.target.classList.add('visible');
						}
					});
				},
				{ threshold: 0.2, rootMargin: '0px 0px -5% 0px' },
			);

			document.querySelectorAll('.character, .character-inline').forEach((element) => {
				charObserver.observe(element);
			});

			window.addEventListener('storage', syncSavedUI);
			window.addEventListener('DOMContentLoaded', syncSavedUI);
			window.addEventListener('saved-events:updated', syncSavedUI);
		</script>
	</body>
</html>
