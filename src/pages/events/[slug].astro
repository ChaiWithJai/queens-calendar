---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EventCard from '../../components/EventCard.astro';
import type { Event } from '../../data/site';
import { events } from '../../data/site';
import { formatLabels, verticalLabels } from '../../lib/format';

export function getStaticPaths() {
	return events.map((event) => ({ params: { slug: event.slug }, props: { event } }));
}

const { event } = Astro.props;
const relatedEvents = events
	.filter((candidate) => candidate.id !== event.id && (candidate.vertical === event.vertical || candidate.date === event.date))
	.slice(0, 3);

const verticalColorMap: Record<Event['vertical'], string> = {
	'civic-tech': '#f9873e',
	'south-asian': '#8f73ff',
	immigrant: '#78d38b',
	'ai-agents': '#d67138',
	fintech: '#6aa67a',
	healthtech: '#f99476',
	climate: '#86bf7a',
	devtools: '#8088d8',
	creative: '#ffb85d',
	community: '#d29685',
	general: '#cfa16a',
};

const verticalImageMap: Partial<Record<Event['vertical'], string>> = {
	'civic-tech': '/images/verticals/civic-tech.png',
	'south-asian': '/images/verticals/south-asian.png',
	immigrant: '/images/verticals/immigrant.png',
	'ai-agents': '/images/verticals/ai-agents.png',
	fintech: '/images/verticals/fintech.png',
	healthtech: '/images/verticals/healthtech.png',
	climate: '/images/verticals/climate.png',
	devtools: '/images/verticals/devtools.png',
	creative: '/images/verticals/creative.png',
	community: '/images/verticals/community.png',
};

const startDate = new Date(event.startTime);
const endDate = new Date(event.endTime);
const dateStr = startDate.toLocaleDateString('en-US', {
	timeZone: 'America/New_York',
	weekday: 'long',
	month: 'long',
	day: 'numeric',
	year: 'numeric',
});
const timeStr = `${startDate.toLocaleTimeString('en-US', { timeZone: 'America/New_York', hour: 'numeric', minute: '2-digit', hour12: true })} – ${endDate.toLocaleTimeString('en-US', { timeZone: 'America/New_York', hour: 'numeric', minute: '2-digit', hour12: true })}`;

const fillingUp = Boolean(event.capacity && event.rsvpCount >= event.capacity * 0.8);
const soldOut = Boolean(event.capacity && event.rsvpCount >= event.capacity);
const spotsLeft = event.capacity ? Math.max(0, event.capacity - event.rsvpCount) : null;
const verticalColor = verticalColorMap[event.vertical] || '#cfa16a';
const eventImage = event.coverImage.url !== '/favicon.svg' ? event.coverImage.url : (verticalImageMap[event.vertical] || '/images/verticals/default.png');

const icsStart = startDate.toISOString().replace(/[-:]/g, '').split('.')[0] + 'Z';
const icsEnd = endDate.toISOString().replace(/[-:]/g, '').split('.')[0] + 'Z';
const icsContent = `BEGIN:VCALENDAR\nVERSION:2.0\nBEGIN:VEVENT\nDTSTART:${icsStart}\nDTEND:${icsEnd}\nSUMMARY:${event.title}\nLOCATION:${event.venue.name}, ${event.venue.address}\nDESCRIPTION:${event.shortDescription}\nURL:${event.externalUrl}\nEND:VEVENT\nEND:VCALENDAR`;
const formattedDescription = event.description
	.replace(/\n{2,}/g, '</p><p>')
	.replace(/^/, '<p>')
	.replace(/$/, '</p>')
	.replace(/## (.*?)(<\/p>|$)/g, '</p><h2>$1</h2><p>')
	.replace(/### (.*?)(<\/p>|$)/g, '</p><h3 style="font-size:var(--text-title-md);margin-top:var(--space-lg);margin-bottom:var(--space-xs);">$1</h3><p>')
	.replace(/- \*\*(.*?)\*\*: (.*?)(<\/p>|$)/g, '</p><ul><li><strong>$1</strong>: $2</li></ul><p>')
	.replace(/- (.*?)(<\/p>|$)/g, '</p><ul><li>$1</li></ul><p>')
	.replace(/<p><\/p>/g, '');
const eventJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'Event',
	name: event.title,
	description: event.description,
	startDate: event.startTime,
	endDate: event.endTime,
	eventStatus: event.status === 'cancelled' ? 'https://schema.org/EventCancelled' : 'https://schema.org/EventScheduled',
	eventAttendanceMode: event.isVirtual ? 'https://schema.org/OnlineEventAttendanceMode' : 'https://schema.org/OfflineEventAttendanceMode',
	location: event.isVirtual ? { '@type': 'VirtualLocation', url: event.virtualUrl ?? event.externalUrl } : {
		'@type': 'Place', name: event.venue.name,
		address: { '@type': 'PostalAddress', streetAddress: event.venue.address, addressLocality: 'Queens', addressRegion: 'NY', addressCountry: 'US' },
		geo: { '@type': 'GeoCoordinates', latitude: event.venue.coordinates.lat, longitude: event.venue.coordinates.lng },
	},
	organizer: { '@type': 'Organization', name: event.source?.name ?? event.submittedBy ?? 'Queens community organizer', url: event.source?.listingUrl },
	url: `https://queens-calendar.netlify.app/events/${event.slug}`,
	sameAs: event.source?.canonicalUrl ? [event.source.canonicalUrl] : undefined,
};
const faqJsonLd = event.faqs?.length ? { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: event.faqs.map((faq) => ({ '@type': 'Question', name: faq.question, acceptedAnswer: { '@type': 'Answer', text: faq.answer } })) } : null;
---

<BaseLayout title={event.title} description={event.shortDescription} currentPath={`/events/${event.slug}`}>
	<script is:inline type="application/ld+json" set:html={JSON.stringify(eventJsonLd)} />
	{faqJsonLd && <script is:inline type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />}
	<section style="padding-top:var(--space-2xl);">
		<div class="container">
			<nav style="margin-bottom:var(--space-lg);display:flex;gap:var(--space-xs);align-items:center;" aria-label="Breadcrumb">
				<a href="/events" class="label-md text-muted" style="text-decoration:none;">Events</a>
				<span class="text-muted">→</span>
				<span class="label-md">{event.title}</span>
			</nav>

			<div class="event-detail-hero" style="background: var(--surface-container-low);">
				<img src={eventImage} alt={event.coverImage.url !== '/favicon.svg' ? event.coverImage.alt : `${verticalLabels[event.vertical]} event header`} />
			</div>

			<div class="event-detail-header">
				<div class="event-detail-meta">
					<span class="chip chip-nurture" style={`background:${verticalColor}33;color:${verticalColor};`}>
						{verticalLabels[event.vertical]}
					</span>
					<span class="chip" style="background:var(--surface-container-low);">{formatLabels[event.format]}</span>
					{fillingUp && !soldOut && <span class="badge-filling">Filling up</span>}
					{soldOut && <span class="chip" style="background:var(--error);color:white;">Sold out</span>}
				</div>

				<h1 class="event-detail-title">{event.title}</h1>
				{event.subtitle && <p style="font-size:var(--text-title-md);color:var(--on-surface-variant);font-style:italic;">{event.subtitle}</p>}
			</div>
			{event.answerSummary && (
				<section class="surface-panel" aria-labelledby="quick-answer" style="margin-bottom:var(--space-2xl);border-left:3px solid var(--primary);">
					<div class="eyebrow">Quick answer</div>
					<h2 id="quick-answer" style="font-size:1.35rem;margin:.55rem 0;">What should I know about this event?</h2>
					<p class="body-lg">{event.answerSummary}</p>
				</section>
			)}

			<div class="event-detail-info">
				<div>
					<div class="event-detail-description" set:html={formattedDescription} />
				</div>

				<div class="event-detail-sidebar">
					<div class="event-detail-sidebar-card" style="background:var(--surface-container);">
						<div style="display:flex;align-items:center;justify-content:space-between;">
							<div>
								<div class="title-md" style="margin-bottom:var(--space-2xs);">Join this event</div>
								{event.capacity && (
									<div class="label-sm text-muted">
										{event.rsvpCount} / {event.capacity} registered
										{spotsLeft !== null && spotsLeft > 0 && ` · ${spotsLeft} spots left`}
									</div>
								)}
							</div>
						</div>

						{event.capacity && (
							<div style="height:6px;background:var(--surface-container-highest);border-radius:var(--radius-full);overflow:hidden;">
								<div
									style={`height:100%;background:${fillingUp ? 'var(--error-container)' : 'var(--primary-container)'};border-radius:var(--radius-full);width:${Math.min(100, (event.rsvpCount / event.capacity) * 100)}%;transition:width 0.5s ease;`}
								></div>
							</div>
						)}

						<div style="display:flex;gap:var(--space-sm);">
							<a href={event.externalUrl} target="_blank" rel="noopener" class="btn btn-primary" style="flex:1;">
								{event.source ? 'Open organizer page' : soldOut ? 'Join waitlist' : 'RSVP now'}
							</a>
							<button class="save-btn" type="button" data-save-event={event.id} aria-pressed="false" aria-label="Save event" style="width:44px;height:44px;">
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z" /></svg>
								<span class="sr-only" data-save-label>Save</span>
							</button>
						</div>
						<button class="btn btn-ghost btn-sm" type="button" id="share-event" style="width:100%;">Send to the group chat</button>

						<div class="label-sm text-muted">via {event.source?.name ?? (event.externalProvider === 'luma' ? 'Luma' : event.externalProvider === 'partiful' ? 'Partiful' : event.externalProvider === 'eventbrite' ? 'Eventbrite' : 'Direct')}</div>
					</div>

					<div class="event-detail-sidebar-card">
						<div class="event-detail-sidebar-card-title">When</div>
						<div class="info-row">
							<svg class="info-row-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
							<div class="info-row-content">
								<span class="info-row-value">{dateStr}</span>
								<span class="info-row-label">{timeStr} ET</span>
							</div>
						</div>
						<button class="btn btn-ghost btn-sm" id="add-to-cal" style="align-self:flex-start;">Add to calendar</button>
					</div>

					<div class="event-detail-sidebar-card">
						<div class="event-detail-sidebar-card-title">Where</div>
						<div class="info-row">
							<svg class="info-row-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" /><circle cx="12" cy="10" r="3" /></svg>
							<div class="info-row-content">
								<span class="info-row-value">{event.venue.name}</span>
								<span class="info-row-label">{event.venue.address}, {event.venue.neighborhood}</span>
								<span class="info-row-label">{event.venue.city}</span>
							</div>
						</div>
						<a href={`https://maps.google.com/?q=${encodeURIComponent(`${event.venue.address}, ${event.venue.city}`)}`} target="_blank" rel="noopener" class="btn btn-ghost btn-sm" style="align-self:flex-start;">
							Open in Maps
						</a>
					</div>

					{event.source && (
						<div class="event-detail-sidebar-card">
							<div class="event-detail-sidebar-card-title">Source and organizer</div>
							<div class="info-row">
								<div style="width:36px;height:36px;border-radius:var(--radius-full);background:var(--primary-container);display:flex;align-items:center;justify-content:center;flex-shrink:0;font-family:var(--font-display);font-weight:var(--weight-bold);font-size:var(--text-label-md);color:var(--on-primary-fixed);">
									{event.source.name.charAt(0)}
								</div>
								<div class="info-row-content">
									<span class="info-row-value">{event.source.name}</span>
									<span class="info-row-label">Retrieved {new Date(event.source.retrievedAt).toLocaleDateString('en-US')}</span>
								</div>
							</div>
							<a class="btn btn-ghost btn-sm" href={event.source.canonicalUrl} target="_blank" rel="noopener">View original listing</a>
						</div>
					)}

					{event.tags.length > 0 && (
						<div class="event-detail-sidebar-card">
							<div class="event-detail-sidebar-card-title">Tags</div>
							<div style="display:flex;flex-wrap:wrap;gap:var(--space-2xs);">
								{event.tags.map((tag) => (
									<a href={`/events?search=${encodeURIComponent(tag)}`} class="chip" style="background:var(--surface-container-low);">#{tag}</a>
								))}
							</div>
						</div>
					)}
				</div>
			</div>

			{relatedEvents.length > 0 && (
				<div class="related-events">
					<div class="section-header">
						<h2 class="section-title">You might also like</h2>
					</div>
					<div class="grid grid-auto-fill" style="gap:var(--space-md);">
						{relatedEvents.map((related) => <EventCard event={related} variant="compact" />)}
					</div>
				</div>
			)}
			{event.faqs?.length && (
				<section class="related-events" aria-labelledby="event-faqs">
					<div class="section-header"><h2 class="section-title" id="event-faqs">Questions people ask</h2></div>
					<div class="stack-list">{event.faqs.map((faq) => <details class="surface-panel"><summary style="font-weight:700;cursor:pointer">{faq.question}</summary><p class="body-lg" style="margin-top:.8rem">{faq.answer}</p></details>)}</div>
					<div class="button-row" style="margin-top:1rem"><a class="button-secondary" href={`/stories/events/${event.slug}`}>Read the event guide</a>{event.source && <a class="button-ghost" href={event.source.canonicalUrl}>Verify at source</a>}</div>
				</section>
			)}
		</div>
	</section>

	<script is:inline define:vars={{ icsContent, eventTitle: event.title, eventSlug: event.slug }}>
		document.getElementById('add-to-cal')?.addEventListener('click', () => {
			const blob = new Blob([icsContent], { type: 'text/calendar;charset=utf-8' });
			const link = document.createElement('a');
			link.href = URL.createObjectURL(blob);
			link.download = 'queens-event.ics';
			link.click();
			URL.revokeObjectURL(link.href);
		});
		document.getElementById('share-event')?.addEventListener('click', async (clickEvent) => {
			const button = clickEvent.currentTarget;
			const url = new URL(`/events/${eventSlug}`, window.location.origin).href;
			const payload = { title: eventTitle, text: `Want to do this in Queens? ${eventTitle}`, url };
			if (navigator.share) { try { await navigator.share(payload); return; } catch (error) { if (error.name === 'AbortError') return; } }
			await navigator.clipboard.writeText(`${payload.text}\n${url}`);
			const original = button.textContent; button.textContent = 'Link copied ✓'; setTimeout(() => button.textContent = original, 2200);
		});
	</script>
</BaseLayout>
