---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout
	title="Submission received | Build Week NYC"
	description="Your Build Week NYC event submission is in review."
	path="/events/submit/success"
>
	<main>
		<section class="section">
			<div class="container">
				<div class="section-band stack-list" style="max-width: 48rem; margin-inline: auto; text-align: center;">
					<div class="eyebrow">Submission received</div>
					<h1 class="headline-section">Your event is in review.</h1>
					<p class="body-lg">
						We have the intake and the team will review it against the week&apos;s curation rules.
						When approved, it will appear in the public directory and saved schedule flow.
					</p>
					<div class="button-row" style="justify-content: center;">
						<a class="button-primary" href="/events">Back to events</a>
						<a class="button-ghost" href="/events/submit">Submit another</a>
					</div>
				</div>
			</div>
		</section>
	</main>
</BaseLayout>
