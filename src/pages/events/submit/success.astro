---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout
	title="Submission received"
	description="Your Queens Calendar event submission is in review."
	path="/events/submit/success"
>
	<main>
		<section class="section">
			<div class="container">
				<div class="section-band stack-list" style="max-width: 48rem; margin-inline: auto; text-align: center;">
					<div class="eyebrow">Submission received</div>
					<h1 class="headline-section">Your event is in review.</h1>
					<p class="body-lg">
						We’ve got the details. We’ll verify the date, Queens location, organizer, and registration link.
						If it’s approved, it will appear in the calendar, map, guides, and saved plans.
					</p>
					<div class="button-row" style="justify-content: center;">
						<a class="button-primary" href="/events">Back to events</a>
						<a class="button-ghost" href="/events/submit">Submit another</a>
					</div>
				</div>
			</div>
		</section>
	</main>
</BaseLayout>
