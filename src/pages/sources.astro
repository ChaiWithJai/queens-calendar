---
import BaseLayout from '../layouts/BaseLayout.astro';
import report from '../data/generated/ingest-report.json';
const formatted = report.generatedAt ? new Intl.DateTimeFormat('en-US', { dateStyle:'long', timeStyle:'short', timeZone:'America/New_York' }).format(new Date(report.generatedAt)) : 'Not run yet';
const retained = report.catalogStatus === 'retained-last-good';
---
<BaseLayout title="Event sources" description="The source and ingestion health ledger behind Queens Calendar." currentPath="/sources">
	<main class="section"><div class="container stack-list" style="gap:2rem"><header class="section-band stack-list"><p class="eyebrow">Provenance ledger</p><h1 class="headline-display">No mystery listings.</h1><p class="body-lg">Every published event keeps its canonical URL, retrieval time, extraction method, organizer, and coordinates. Failed sources stay visible so gaps can be fixed instead of filled with invented events.</p>{retained && <p class="body-lg"><strong>Last-good catalog retained:</strong> the latest run accepted no fresh records, so the previously validated catalog remains published instead of being erased.</p>}<div class="chip-row"><span class="chip is-positive">Last run: {formatted}</span><span class="chip">{report.totals.discovered} discovered</span><span class="chip">{report.totals.published} published</span><span class="chip">{report.totals.rejected} rejected</span></div></header>
		<section class="stack-list"><h2 class="section-title">Pipeline health</h2>{report.sources.map((source) => <article class="surface-panel split-grid"><div><p class="eyebrow">{source.status}</p><h3 style="margin:.5rem 0">{source.name}</h3><p class="body-lg">{source.accepted} accepted from {source.discovered} discovered · {source.durationMs} ms</p></div><div>{source.errors.length ? <ul class="body-lg">{source.errors.slice(0,3).map((error) => <li>{error}</li>)}</ul> : <span class="chip is-positive">No transport errors</span>}{source.rejections?.length ? <details style="margin-top:.5rem"><summary class="body-lg">Why events were rejected ({source.rejected})</summary><ul class="body-lg">{source.rejections.map((r) => <li><a href={r.link}>{r.link}</a>: {r.reasons.join(', ')}</li>)}</ul></details> : null}</div></article>)}</section>
		<section class="surface-panel"><p class="eyebrow">Open data contract</p><h2 style="margin:.5rem 0">Build against the same schema</h2><p class="body-lg">The public catalog and validation schema are versionable JSON endpoints.</p><div class="button-row" style="margin-top:1rem"><a class="button-primary" href="/api/events">Event catalog</a><a class="button-ghost" href="/api/schema">JSON Schema</a><a class="button-ghost" href="/api/ingest-report">Ingest report</a></div></section>
	</div></main>
</BaseLayout>
