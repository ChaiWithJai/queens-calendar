---
import BaseLayout from '../layouts/BaseLayout.astro';
import EventCard from '../components/EventCard.astro';
import TrackCard from '../components/TrackCard.astro';
import { events, getFeaturedEvents, getFlagshipEvents, siteStats, tracks } from '../data/site';
import { formatLongDateLabel, groupEventsByDate } from '../lib/format';

const featuredEvents = getFeaturedEvents().slice(0, 4);
const flagshipEvents = getFlagshipEvents().slice(0, 3);
const groupedEvents = groupEventsByDate(events);
const previewDays = Object.entries(groupedEvents).slice(0, 4);
const totalVenues = new Set(events.map((event) => event.venue.id)).size;
const totalRsvps = events.reduce((sum, event) => sum + event.rsvpCount, 0);
---

<BaseLayout
	title="Build Week NYC"
	description="A builder-first, Astro-powered directory for NYC tech week with filters, schedule saving, and track-driven discovery."
>
	<main>
		<section class="hero--crown-jewel" id="hero" style="border-bottom: 2px solid var(--surface-container-highest);">
			<img src="/images/hero-bg.png" alt="NYC skyline at sunset" class="hero-background-image" fetchpriority="high" />
			<div class="hero-bg-glow"></div>
			<div class="hero-bg-glow hero-bg-glow--secondary"></div>

			<div class="hero-character hero-character--jai character-float" aria-hidden="true">
				<img src="/characters/jai/waving.png" alt="" loading="eager" />
			</div>
			<div class="hero-character hero-character--asha character-float" aria-hidden="true">
				<img src="/characters/asha/pointing.png" alt="" loading="eager" />
			</div>
			<div class="hero-character hero-character--bot character-rock" aria-hidden="true">
				<img src="/characters/bw-bot/idle.png" alt="" loading="eager" />
			</div>

			<div class="container hero-container">
				<div class="hero-content-glass">
					<div class="hero-badge">June 1–7, 2026 · New York City</div>
					<h1 class="hero-title">
						Build Week
						<br />
						<em>NYC</em>
					</h1>
					<p class="hero-subtitle">
						The builder-first tech week directory. Discover {events.length}+ curated events across civic tech,
						AI, fintech, and community rooms without sponsor-first hierarchy or calendar chaos.
					</p>
					<div class="hero-actions">
						<a class="button-primary" href="/events">Browse all events</a>
						<a class="button-ghost" href="/tracks">View tracks</a>
					</div>
				</div>

				<div class="hero-stats-glass">
					<div class="hero-stat">
						<span class="hero-stat-value">{events.length}+</span>
						<span class="hero-stat-label">Events</span>
					</div>
					<div class="hero-stat">
						<span class="hero-stat-value">{totalVenues}</span>
						<span class="hero-stat-label">Venues</span>
					</div>
					<div class="hero-stat">
						<span class="hero-stat-value">{totalRsvps.toLocaleString()}+</span>
						<span class="hero-stat-label">RSVPs</span>
					</div>
					<div class="hero-stat">
						<span class="hero-stat-value">{siteStats[0]?.value}</span>
						<span class="hero-stat-label">Tracks</span>
					</div>
				</div>
			</div>
		</section>

		<section class="section-gap" id="flagship-events" style="background: var(--surface-container-low);">
			<div class="container">
				<div class="section-header">
					<h2 class="section-title">Flagship Events</h2>
					<a href="/events" class="section-link">See all events</a>
				</div>

				<div class="stack-list" style="gap: 1.5rem;">
					{flagshipEvents.map((event) => <EventCard event={event} variant="featured" />)}
				</div>
			</div>
		</section>

		<section class="section-gap" id="tracks-preview">
			<div class="container">
				<div class="section-header">
					<h2 class="section-title">Curated Tracks</h2>
					<a href="/tracks" class="section-link">All tracks</a>
				</div>
				<p class="body-lg" style="margin-bottom: 1.5rem; max-width: 60ch;">
					Narrative-led curation instead of one giant flat list. Follow a track to move through the week with
					context, not tab-sprawl.
				</p>

				<div class="track-grid">
					{tracks.map((track) => <TrackCard track={track} />)}
				</div>
			</div>
		</section>

		<section class="section-gap" id="day-by-day" style="background: var(--surface-container-low);">
			<div class="container">
				<div class="section-header">
					<h2 class="section-title">Day by Day</h2>
					<a href="/events" class="section-link">Full calendar</a>
				</div>

				<div class="stack-list" style="gap: 2rem;">
					{previewDays.map(([day, dayEvents]) => (
						<div class="day-group" id={`day-${day}`}>
							<div class="day-group-header">
								<h3 class="day-group-name">{formatLongDateLabel(day)}</h3>
								<span class="day-group-count">{dayEvents.length} events</span>
							</div>
							<div class="day-group-events">
								{dayEvents.slice(0, 4).map((event) => <EventCard event={event} />)}
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<section class="section-gap" id="featured-events">
			<div class="container">
				<div class="section-header">
					<h2 class="section-title">More Worth Your Attention</h2>
					<a href="/schedule" class="section-link">View saved schedule</a>
				</div>

				<div class="day-group-events">
					{featuredEvents.map((event) => <EventCard event={event} />)}
				</div>
			</div>
		</section>

		<section class="section-gap" id="newsletter">
			<div class="container">
				<div class="newsletter-cta">
					<h2 class="headline-section" style="font-size: clamp(2rem, 1.4rem + 2vw, 3rem);">
						Stay in the loop
					</h2>
					<p class="body-lg" style="max-width: 46ch; text-align: center;">
						Get updates on new event drops, track highlights, and last-minute additions without losing the
						builder-first focus.
					</p>
					<form class="newsletter-form">
						<input type="email" placeholder="you@example.com" aria-label="Email address" />
						<button type="submit" class="button-primary">Let&apos;s go</button>
					</form>
				</div>
			</div>
		</section>
	</main>
</BaseLayout>
