---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { events } from '../../data/site';
import { eventsByWeek, eventStory, weekStory } from '../../lib/editorial';
---
<BaseLayout title="Queens event stories" description="Source-backed guides to individual Queens events and the week ahead.">
	<main class="section"><div class="container stack-list" style="gap:2rem">
		<header class="section-band stack-list"><p class="eyebrow">The useful version</p><h1 class="headline-display">What to do, without twelve tabs.</h1><p class="body-lg">Fast answers for individual events and sendable week plans—with direct organizer links when you are ready to go.</p></header>
		<section><div class="section-header"><h2 class="section-title">Week guides</h2></div><div class="card-grid">
			{Object.entries(eventsByWeek).map(([week, weekEvents]) => { const story = weekStory(week, weekEvents ?? []); return <article class="surface-panel span-6"><p class="eyebrow">{story.range}</p><h3 style="margin:.6rem 0"><a href={`/stories/weeks/${week}`}>{story.headline}</a></h3><p class="body-lg">{story.dek}</p></article>; })}
		</div></section>
		<section><div class="section-header"><h2 class="section-title">Event guides</h2></div><div class="card-grid">
			{events.map((event) => { const story = eventStory(event); return <article class="surface-panel span-6"><p class="eyebrow">{event.venue.neighborhood}</p><h3 style="margin:.6rem 0"><a href={`/stories/events/${event.slug}`}>{story.headline}</a></h3><p class="body-lg">{story.dek}</p></article>; })}
		</div></section>
	</div></main>
</BaseLayout>
