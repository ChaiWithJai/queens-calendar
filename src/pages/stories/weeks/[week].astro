---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { eventsByWeek, weekStory } from '../../../lib/editorial';
export function getStaticPaths() { return Object.entries(eventsByWeek).map(([week, weekEvents]) => ({ params:{ week }, props:{ week, weekEvents:weekEvents ?? [] } })); }
const { week, weekEvents } = Astro.props;
const story = weekStory(week, weekEvents);
const listJsonLd = { '@context':'https://schema.org', '@type':'ItemList', name:story.headline, numberOfItems:weekEvents.length, itemListElement:weekEvents.map((event, index) => ({ '@type':'ListItem', position:index+1, url:`https://queens-calendar.netlify.app/events/${event.slug}`, item:{ '@type':'Event', name:event.title, startDate:event.startTime, location:{ '@type':'Place', name:event.venue.name, address:event.venue.address } } })) };
---
<BaseLayout title={story.headline} description={story.dek} currentPath={`/stories/weeks/${week}`}>
	<script is:inline type="application/ld+json" set:html={JSON.stringify(listJsonLd)} />
	<main class="section"><article class="container stack-list" style="gap:2rem"><header class="section-band stack-list"><p class="eyebrow">Week guide · {week}</p><h1 class="headline-display" style="font-size:clamp(2.5rem,6vw,4.5rem)">{story.headline}</h1><p class="body-lg">{story.dek}</p><div class="chip-row">{story.neighborhoods.map((item) => <span class="chip">{item}</span>)}{story.topics.map((item) => <span class="chip is-positive">{item}</span>)}</div></header>
		<section class="stack-list"><h2 class="section-title">The sourced event list</h2>{weekEvents.map((event) => <article class="surface-panel split-grid"><div><p class="eyebrow">{event.venue.neighborhood}</p><h3 style="margin:.5rem 0"><a href={`/stories/events/${event.slug}`}>{event.title}</a></h3><p class="body-lg">{event.answerSummary}</p></div><div class="button-row"><a class="button-primary" href={`/events/${event.slug}`}>Event details</a><a class="button-ghost" href={event.source?.canonicalUrl ?? event.externalUrl}>Source</a></div></article>)}</section>
	</article></main>
</BaseLayout>
