---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { events } from '../../../data/site';
import { eventStory } from '../../../lib/editorial';
export function getStaticPaths() { return events.map((event) => ({ params: { slug: event.slug }, props: { event } })); }
const { event } = Astro.props;
const story = eventStory(event);
const published = event.source?.retrievedAt ?? new Date().toISOString();
const blogJsonLd = { '@context':'https://schema.org', '@type':'BlogPosting', headline:story.headline, description:story.dek, datePublished:published, dateModified:published, mainEntityOfPage:`https://queens-calendar.netlify.app/stories/events/${event.slug}`, about:{ '@type':'Event', name:event.title, startDate:event.startTime, endDate:event.endTime, eventAttendanceMode:event.isVirtual ? 'https://schema.org/OnlineEventAttendanceMode' : 'https://schema.org/OfflineEventAttendanceMode', location:{ '@type':'Place', name:event.venue.name, address:event.venue.address }, url:event.source?.canonicalUrl ?? event.externalUrl } };
---
<BaseLayout title={story.headline} description={story.dek} currentPath={`/stories/events/${event.slug}`}>
	<script is:inline type="application/ld+json" set:html={JSON.stringify(blogJsonLd)} />
	<main class="section"><article class="container" style="max-width:820px"><nav class="eyebrow"><a href="/stories">Stories</a> / Event guide</nav><header class="section-band stack-list" style="margin-top:1rem"><p class="eyebrow">{event.venue.neighborhood} · {event.weekKey}</p><h1 class="headline-display" style="font-size:clamp(2.5rem,6vw,4.5rem)">{story.headline}</h1><p class="body-lg">{story.dek}</p></header>
		<div class="prose stack-list" style="margin-top:2rem">{story.paragraphs.map((paragraph) => <p class="body-lg">{paragraph}</p>)}<div class="surface-panel"><h2 style="font-size:1.3rem">Quick answer</h2><p class="body-lg" style="margin-top:.6rem">{event.answerSummary}</p></div><h2 style="font-size:1.5rem">Common questions</h2>{event.faqs?.map((faq) => <section><h3 style="font-size:1.05rem">{faq.question}</h3><p class="body-lg">{faq.answer}</p></section>)}<div class="button-row"><a class="button-primary" href={`/events/${event.slug}`}>Open calendar listing</a><a class="button-ghost" href={event.source?.canonicalUrl ?? event.externalUrl}>View original source</a></div></div>
	</article></main>
</BaseLayout>
