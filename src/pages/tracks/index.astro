---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TrackCard from '../../components/TrackCard.astro';
import { tracks } from '../../data/site';
---

<BaseLayout
	title="Curated Tracks"
	description="Explore curated event tracks for Build Week NYC: Great Civilization, South Asian Builders, O-1 Builders, and more."
	currentPath="/tracks"
>
	<section style="padding-top:var(--space-2xl);">
		<div class="container">
			<div style="margin-bottom:var(--space-2xl);max-width:60ch;">
				<h1 class="display-sm" style="margin-bottom:var(--space-sm);">Curated Tracks</h1>
				<p class="body-lg text-muted">
					Tracks compress the week into coherent narratives. Follow one when you want signal, not just a giant undifferentiated calendar.
				</p>
			</div>

			<div style="display:flex;flex-direction:column;gap:var(--space-xl);">
				{tracks.map((track) => <TrackCard track={track} />)}
			</div>
		</div>
	</section>
</BaseLayout>
