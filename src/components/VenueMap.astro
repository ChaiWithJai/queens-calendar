---
import type { Event, Venue } from '../data/site';

interface VenueGroup { venue: Venue; events: Event[]; }
interface Props { groups: VenueGroup[]; }
const { groups } = Astro.props;
const points = groups.map((group) => ({
	id: group.venue.id,
	name: group.venue.name,
	address: group.venue.address,
	neighborhood: group.venue.neighborhood,
	lat: group.venue.coordinates.lat,
	lng: group.venue.coordinates.lng,
	events: group.events.map((event) => ({ title: event.title, slug: event.slug, start: event.startTime, mode: event.isVirtual ? 'Online' : 'In person' })),
}));
---

<section class="real-map-shell" aria-labelledby="map-title">
	<div class="map-heading">
		<div>
			<p class="eyebrow">Geographic discovery</p>
			<h2 id="map-title">Explore events by place</h2>
		</div>
		<p>{points.length} mapped {points.length === 1 ? 'venue' : 'venues'} · OpenStreetMap</p>
	</div>
	<div class="event-map" data-event-map data-points={JSON.stringify(points)} aria-label="Interactive map of Queens events"></div>
	<noscript><p class="map-fallback">Enable JavaScript for the interactive map. Venue links remain available below.</p></noscript>
</section>

<script>
	import L from 'leaflet';
	import 'leaflet/dist/leaflet.css';

	const escapeHtml = (value: string) => value.replace(/[&<>'"]/g, (character) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', "'": '&#39;', '"': '&quot;' })[character] ?? character);
	document.querySelectorAll<HTMLElement>('[data-event-map]').forEach((element) => {
		if (element.dataset.initialized === 'true') return;
		element.dataset.initialized = 'true';
		const points = JSON.parse(element.dataset.points || '[]');
		const map = L.map(element, { scrollWheelZoom: false }).setView([40.7282, -73.7949], 11);
		L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
			maxZoom: 19,
			attribution: '&copy; OpenStreetMap contributors',
		}).addTo(map);
		const bounds: L.LatLngTuple[] = [];
		points.forEach((point: any) => {
			if (!Number.isFinite(point.lat) || !Number.isFinite(point.lng)) return;
			bounds.push([point.lat, point.lng]);
			const marker = L.circleMarker([point.lat, point.lng], { radius: 9, color: '#159bff', weight: 2, fillColor: '#53d8a0', fillOpacity: 0.9 }).addTo(map);
			const eventLinks = point.events.map((event: any) => `<li><a href="/events/${encodeURIComponent(event.slug)}">${escapeHtml(event.title)}</a> <small>${escapeHtml(event.mode)}</small></li>`).join('');
			marker.bindPopup(`<div class="qc-map-popup"><strong>${escapeHtml(point.name)}</strong><p>${escapeHtml(point.address)} · ${escapeHtml(point.neighborhood)}</p><ul>${eventLinks}</ul></div>`, { maxWidth: 320 });
		});
		if (bounds.length > 1) map.fitBounds(bounds, { padding: [34, 34], maxZoom: 14 });
		else if (bounds.length === 1) map.setView(bounds[0], 14);
		setTimeout(() => map.invalidateSize(), 50);
	});
</script>

<style>
	.real-map-shell{border:1px solid var(--outline-variant);border-radius:12px;background:var(--surface-container);overflow:hidden}.map-heading{display:flex;justify-content:space-between;align-items:flex-end;gap:1rem;padding:1rem 1.15rem;border-bottom:1px solid var(--outline-variant)}.map-heading h2{font-size:1.35rem;margin-top:.25rem}.map-heading>p{font-family:ui-monospace,SFMono-Regular,Menlo,monospace;font-size:.7rem;color:var(--on-surface-variant)}.event-map{height:min(65vh,620px);min-height:430px;background:#111315;z-index:1}.map-fallback{padding:1rem}.event-map :global(.leaflet-popup-content-wrapper),.event-map :global(.leaflet-popup-tip){background:#111315;color:#f3f5f7}.event-map :global(.leaflet-popup-content){margin:1rem;min-width:230px}.event-map :global(.qc-map-popup p){color:#9ba2a9;margin:.4rem 0 .65rem;font-size:.78rem}.event-map :global(.qc-map-popup ul){display:grid;gap:.45rem}.event-map :global(.qc-map-popup a){color:#41acff}.event-map :global(.qc-map-popup small){color:#7d858c}@media(max-width:620px){.map-heading{align-items:flex-start;flex-direction:column}.event-map{min-height:58vh}}
</style>
