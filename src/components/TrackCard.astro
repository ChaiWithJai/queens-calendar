---
import type { Track } from '../data/site';
import { getTrackEvents } from '../data/site';

interface Props {
	track: Track;
}

const { track } = Astro.props;
const trackEvents = getTrackEvents(track.id);
---

<a href={`/tracks/${track.slug}`} class="track-card">
	<div class="track-card-accent" style={`background:${track.color};`}></div>
	<div class="track-card-body">
		<h3 class="track-card-name">{track.name}</h3>
		<p class="track-card-desc">{track.description}</p>
		<div class="track-card-meta">
			<span class="chip chip-nurture" style={`background:${track.color}22; color:${track.color};`}>
				{trackEvents.length} events
			</span>
			<span class="section-link" style="margin-left:auto;">Explore track</span>
		</div>
	</div>
</a>
