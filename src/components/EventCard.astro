---
import type { Event } from '../data/site';
import {
	formatLabels,
	formatWeekdayLabel,
	formatTimeRange,
	getSpotsLabel,
	verticalLabels,
} from '../lib/format';

interface Props {
	event: Event;
	variant?: 'compact' | 'featured';
}

const { event, variant = 'compact' } = Astro.props;

const verticalColorMap: Record<Event['vertical'], string> = {
	'civic-tech': '#f9873e',
	'south-asian': '#8f73ff',
	immigrant: '#78d38b',
	'ai-agents': '#d67138',
	fintech: '#6aa67a',
	healthtech: '#f99476',
	climate: '#86bf7a',
	devtools: '#8088d8',
	creative: '#ffb85d',
	community: '#d29685',
	general: '#cfa16a',
};

const verticalImageMap: Partial<Record<Event['vertical'], string>> = {
	'civic-tech': '/images/verticals/civic-tech.png',
	'south-asian': '/images/verticals/south-asian.png',
	immigrant: '/images/verticals/immigrant.png',
	'ai-agents': '/images/verticals/ai-agents.png',
	fintech: '/images/verticals/fintech.png',
	healthtech: '/images/verticals/healthtech.png',
	climate: '/images/verticals/climate.png',
	devtools: '/images/verticals/devtools.png',
	creative: '/images/verticals/creative.png',
	community: '/images/verticals/community.png',
};

const accent = verticalColorMap[event.vertical] || '#cfa16a';
const image = verticalImageMap[event.vertical] || '/images/verticals/default.png';
const fillingUp = Boolean(event.capacity && event.rsvpCount >= event.capacity * 0.8);
const soldOut = Boolean(event.capacity && event.rsvpCount >= event.capacity);
---

<article class:list={['event-card', variant === 'featured' && 'event-card-featured', variant === 'featured' && 'card-stack']}>
	{variant === 'featured' && (
		<div class="event-card-image" style={`background: linear-gradient(135deg, ${accent}44, ${accent}18);`}>
			<img src={image} alt={`${verticalLabels[event.vertical]} illustration`} loading="lazy" width="600" height="400" />
		</div>
	)}

	<div class="event-card-body">
		<div class="event-card-meta">
			<span class="chip chip-nurture" style={`background:${accent}26; color:${accent};`}>
				{event.track?.name ?? verticalLabels[event.vertical]}
			</span>
			<span class="chip">{formatLabels[event.format]}</span>
			{event.isFlagship && <span class="chip is-secondary">Flagship</span>}
			{fillingUp && !soldOut && <span class="badge-filling">Filling up</span>}
			{soldOut && <span class="chip chip-danger">Sold out</span>}
		</div>

		<h3 class="event-card-title">
			<a href={`/events/${event.slug}`}>{event.title}</a>
		</h3>
		{event.subtitle && <p class="event-card-subtitle">{event.subtitle}</p>}
		<p class="event-card-desc">{event.shortDescription}</p>

		<div class="event-card-footer">
			<div class="event-card-details">
				<div class="event-card-time">
					<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
						<circle cx="12" cy="12" r="10"></circle>
						<path d="M12 6v6l4 2"></path>
					</svg>
					{formatWeekdayLabel(event.date)} · {formatTimeRange(event.startTime, event.endTime)}
				</div>
				<div class="event-card-venue">
					<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
						<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
						<circle cx="12" cy="10" r="3"></circle>
					</svg>
					{event.venue.name} · {event.venue.neighborhood}
				</div>
				<div class="event-card-capacity">{getSpotsLabel(event)}</div>
			</div>

			<div class="event-card-actions">
				<button
					class="save-btn"
					type="button"
					data-save-event={event.id}
					data-saved="false"
					aria-pressed="false"
					aria-label="Save event"
				>
					<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
						<path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"></path>
					</svg>
					<span class="sr-only" data-save-label>Save</span>
				</button>
				<a class="button-ghost" href={`/events/${event.slug}`}>Details</a>
				<a class="button-primary" href={event.externalUrl} target="_blank" rel="noreferrer">RSVP</a>
			</div>
		</div>
	</div>
</article>
