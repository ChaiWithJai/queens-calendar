---
import type { Event } from '../data/site';
import { formatLabels, verticalLabels } from '../lib/format';

interface Props {
	event: Event;
	variant?: 'compact' | 'featured';
}

const { event, variant = 'compact' } = Astro.props;

const verticalColorMap: Record<Event['vertical'], string> = {
	'civic-tech': '#f9873e',
	'south-asian': '#8f73ff',
	immigrant: '#78d38b',
	'ai-agents': '#d67138',
	fintech: '#6aa67a',
	healthtech: '#f99476',
	climate: '#86bf7a',
	devtools: '#8088d8',
	creative: '#ffb85d',
	community: '#d29685',
	general: '#cfa16a',
};

const verticalImageMap: Partial<Record<Event['vertical'], string>> = {
	'civic-tech': '/images/verticals/civic-tech.png',
	'south-asian': '/images/verticals/south-asian.png',
	immigrant: '/images/verticals/immigrant.png',
	'ai-agents': '/images/verticals/ai-agents.png',
	fintech: '/images/verticals/fintech.png',
	healthtech: '/images/verticals/healthtech.png',
	climate: '/images/verticals/climate.png',
	devtools: '/images/verticals/devtools.png',
	creative: '/images/verticals/creative.png',
	community: '/images/verticals/community.png',
};

const accent = verticalColorMap[event.vertical] || '#cfa16a';
const image = verticalImageMap[event.vertical] || '/images/verticals/default.png';
const fillingUp = Boolean(event.capacity && event.rsvpCount >= event.capacity * 0.8);
const soldOut = Boolean(event.capacity && event.rsvpCount >= event.capacity);

const startDate = new Date(event.startTime);
const endDate = new Date(event.endTime);
const timeFormat: Intl.DateTimeFormatOptions = { timeZone: 'America/New_York', hour: 'numeric', minute: '2-digit', hour12: true };
const timeStr = `${startDate.toLocaleTimeString('en-US', timeFormat)} – ${endDate.toLocaleTimeString('en-US', timeFormat)}`;
const dateStr = startDate.toLocaleDateString('en-US', { timeZone: 'America/New_York', weekday: 'short', month: 'short', day: 'numeric' });
---

{variant === 'featured' ? (
	<article
		class="event-card event-card-featured card-stack stagger-in"
		id={`event-${event.id}`}
		data-vertical={event.vertical}
		data-format={event.format}
		data-date={event.date}
		data-day={event.dayOfWeek}
	>
		<div class="event-card-image" style={`background: linear-gradient(135deg, ${accent}44, ${accent}22);`}>
			<img src={image} alt={`${verticalLabels[event.vertical]} event illustration`} width="600" height="400" loading="lazy" />
		</div>
		<div class="event-card-body">
			<div class="event-card-meta">
				<span class="chip chip-nurture" style={`background:${accent}33;color:${accent};`}>
					{event.track?.name ?? verticalLabels[event.vertical]}
				</span>
				<span class="chip" style="background:var(--surface-container-low);">{formatLabels[event.format]}</span>
				{event.isFlagship && <span class="chip" style="background:var(--primary-container);color:var(--on-primary-fixed);">Flagship</span>}
				{fillingUp && !soldOut && <span class="badge-filling">Filling up</span>}
				{soldOut && <span class="chip" style="background:var(--error);color:white;">Sold out</span>}
			</div>
			<h3 class="event-card-title">
				<a href={`/events/${event.slug}`}>{event.title}</a>
			</h3>
			{event.subtitle && <p class="event-card-subtitle">{event.subtitle}</p>}
			<p class="event-card-desc">{event.shortDescription}</p>
			<div class="event-card-footer">
				<div class="event-card-details">
					<div class="event-card-time">
						<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10" /><path d="M12 6v6l4 2" /></svg>
						{dateStr} · {timeStr}
					</div>
					<div class="event-card-venue">
						<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" /><circle cx="12" cy="10" r="3" /></svg>
						{event.venue.name}
					</div>
				</div>
				<div class="event-card-actions">
					<button class="save-btn" type="button" data-save-event={event.id} aria-pressed="false" aria-label="Save event">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z" /></svg>
						<span class="sr-only" data-save-label>Save</span>
					</button>
					<a href={event.externalUrl} target="_blank" rel="noopener" class="btn btn-primary btn-sm">RSVP</a>
				</div>
			</div>
		</div>
	</article>
) : (
	<article
		class="event-card stagger-in"
		id={`event-${event.id}`}
		data-vertical={event.vertical}
		data-format={event.format}
		data-date={event.date}
		data-day={event.dayOfWeek}
	>
		<div class="event-card-body">
			<div class="event-card-meta">
				<span class="chip chip-nurture" style={`background:${accent}33;color:${accent};font-size:var(--text-label-sm);`}>
					{event.track?.name ?? verticalLabels[event.vertical]}
				</span>
				<span class="chip" style="background:var(--surface-container-low);font-size:var(--text-label-sm);">{formatLabels[event.format]}</span>
				{event.isFlagship && <span class="chip" style="background:var(--primary-container);color:var(--on-primary-fixed);font-size:var(--text-label-sm);">Flagship</span>}
				{fillingUp && !soldOut && <span class="badge-filling">Filling up</span>}
				{soldOut && <span class="chip" style="background:var(--error);color:white;font-size:var(--text-label-sm);">Sold out</span>}
			</div>
			<h3 class="event-card-title">
				<a href={`/events/${event.slug}`}>{event.title}</a>
			</h3>
			<p class="event-card-desc">{event.shortDescription}</p>
			<div class="event-card-footer">
				<div class="event-card-details">
					<div class="event-card-time">
						<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10" /><path d="M12 6v6l4 2" /></svg>
						{timeStr}
					</div>
					<div class="event-card-venue">
						<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" /><circle cx="12" cy="10" r="3" /></svg>
						{event.venue.name}
					</div>
				</div>
				<div class="event-card-actions">
					<button class="save-btn" type="button" data-save-event={event.id} aria-pressed="false" aria-label="Save event">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z" /></svg>
						<span class="sr-only" data-save-label>Save</span>
					</button>
					<a href={event.externalUrl} target="_blank" rel="noopener" class="btn btn-primary btn-sm">RSVP</a>
				</div>
			</div>
		</div>
	</article>
)}
